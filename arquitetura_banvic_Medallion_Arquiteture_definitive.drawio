        <mxCell id="raw_box" parent="dwh_container" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#d79b00;align=left;verticalAlign=top;spacingLeft=10;spacingTop=100;dashed=1;dashPattern=8 8;" value="&lt;font&gt;Dados espelhados da origem, sem transformação ou alteração de nomes.&lt;br&gt;&lt;b style=&quot;&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;div&gt;&lt;font&gt;&lt;b style=&quot;&quot;&gt;Tipo de Objeto:&lt;/b&gt; Tabelas&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;b style=&quot;&quot;&gt;Método de Carga:&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;• Processamento Batch&lt;br&gt;• Full Load&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;b style=&quot;&quot;&gt;Transformação:&lt;/b&gt; Nenhuma&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;b style=&quot;&quot;&gt;Modelagem:&lt;/b&gt; Nenhuma&lt;/font&gt;&lt;/div&gt;" vertex="1">
