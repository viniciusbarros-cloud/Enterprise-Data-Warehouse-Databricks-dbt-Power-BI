        <mxCell id="staging_box" parent="dwh_container" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=10;spacingTop=100;dashed=1;dashPattern=8 8;" value="Primeira camada dbt. Aplicação de boas práticas de engenharia de software (DataOps)&lt;br&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;div&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Tipo de Objeto:&lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt; Views&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;b&gt;Método de Carga:&lt;/b&gt; dbt run&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;b&gt;Transformações:&lt;/b&gt;&lt;br&gt;• Renomeação de colunas&lt;/div&gt;&lt;div&gt;&lt;br&gt;• Cast de tipos de dados&lt;/div&gt;&lt;div&gt;&lt;br&gt;• Tratamento de nulos/vazios&lt;/div&gt;&lt;div&gt;&lt;br&gt;• Limpeza de strings&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;b&gt;Modelagem:&lt;/b&gt; Nenhuma&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="510" width="210" x="280" y="110" as="geometry" />
        </mxCell>
        <mxCell id="intermediate_box" parent="dwh_container" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#b854d4;align=left;verticalAlign=top;spacingLeft=10;spacingTop=100;dashed=1;dashPattern=8 8;" value="Cruzamento e preparo dos dados, bem como, das entidades para o modelo final com foco na análise com aplicação das regras de negócio&lt;br&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;div&gt;&lt;b&gt;Tipo de Objeto:&lt;/b&gt; Views / Ephemeral&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;b&gt;Método de Carga:&lt;/b&gt; dbt run&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;b&gt;Transformações:&lt;/b&gt;&lt;br&gt;• Joins complexos&lt;/div&gt;&lt;div&gt;&lt;br&gt;• Chaves (Surrogate Keys)&lt;/div&gt;&lt;div&gt;&lt;br&gt;• Filtros de regras&lt;/div&gt;&lt;div&gt;&lt;br&gt;• Normalização&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;b&gt;Modelagem:&lt;/b&gt; Entidades&lt;/div&gt;" vertex="1">
